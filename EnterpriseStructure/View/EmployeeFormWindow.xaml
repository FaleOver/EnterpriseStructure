<Window x:Class="Presentation.View.EmployeeFormWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Presentation.View"
        mc:Ignorable="d"
        Title="Форма сотрудника" Height="250" Width="350"
        MinHeight="250" MinWidth="350"
        WindowStartupLocation="CenterOwner">
    <StackPanel Margin="16">
        <HeaderedContentControl Header="Фамилия:">
            <TextBox Text="{Binding LastName, UpdateSourceTrigger=PropertyChanged}" />
        </HeaderedContentControl>
        
        <HeaderedContentControl Header="Имя:" 
                                Margin="0,8,0,0">
            <TextBox Text="{Binding FirstName, UpdateSourceTrigger=PropertyChanged}" />
        </HeaderedContentControl>
        
        <HeaderedContentControl Header="Отчество:" 
                                Margin="0,8,0,0">
            <TextBox Text="{Binding MiddleName, UpdateSourceTrigger=PropertyChanged}" />
        </HeaderedContentControl>

        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0, 16,0,0">
            <Button Content="Сохранить"
                    Command="{Binding SaveCommand}"
                    CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                    Margin="0,0,8,0"
                    Padding="8,4"/>
            
            <Button Content="Отмена" 
                    Command="{Binding CancelCommand}"
                    CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                    Padding="8,4"/>
        </StackPanel>
    </StackPanel>
</Window>
