<Window x:Class="Presentation.View.NewNodeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Presentation.View"
        mc:Ignorable="d"
        Title="Создание новой ветки" Height="200" Width="300"
        MinHeight="200" MinWidth="300"
        WindowStartupLocation="CenterOwner">
    <StackPanel Margin="16">
        <HeaderedContentControl Header="Тип ветки:">
            <ComboBox ItemsSource="{Binding NodeTypes}" 
                      SelectedItem="{Binding SelectedNodeType}" 
                      Margin="0,0,0,8"/>
        </HeaderedContentControl>

        <HeaderedContentControl Header="Название:">
            <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" 
                     MinHeight="22"/>
        </HeaderedContentControl>

        <StackPanel Orientation="Horizontal" 
                    HorizontalAlignment="Right" 
                    Margin="0,16,0,0">
            <Button Content="Создать" 
                    Command="{Binding CreateNodeCommand}"
                    CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                    Margin="0,0,8,0" 
                    Padding="8,4"/>
            
            <Button Content="Отмена" 
                    Command="{Binding CancelCommand}"
                    CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                    Padding="8,4"/>
        </StackPanel>
    </StackPanel>
</Window>
