<Window x:Class="Presentation.View.RenameNodeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Presentation.View"
        mc:Ignorable="d"
        Title="Переименование" Height="150" Width="300"
        MinHeight="150" MinWidth="300"
        WindowStartupLocation="CenterOwner">
    <StackPanel Margin="16">
        <HeaderedContentControl Header="Название:">
            <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" />
        </HeaderedContentControl>
        
        <StackPanel Orientation="Horizontal"
            HorizontalAlignment="Right" 
                    Margin="0,16,0,0">
            <Button Content="Сохранить" 
                    Command="{Binding RenameNodeCommand}" 
                    CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                    Margin="0,0,8,0" Padding="8,4"/>
            
            <Button Content="Отмена" 
                    Command="{Binding CancelCommand}" 
                    CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}" 
                    Padding="8,4"/>
        </StackPanel>
    </StackPanel>
</Window>
